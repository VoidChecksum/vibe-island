{
  "$schema": "https://raw.githubusercontent.com/nicklaurence/tauri/dev/packages/api/schema.json",
  "productName": "Vibe Island",
  "version": "1.0.0",
  "identifier": "app.vibeisland.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "notch",
        "title": "Vibe Island",
        "width": 420,
        "height": 48,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "y": 0,
        "visible": true,
        "shadow": false
      },
      {
        "label": "settings",
        "title": "Vibe Island Settings",
        "width": 560,
        "height": 640,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "tooltip": "Vibe Island"
    },
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "plugins": {
    "shell": { "open": true },
    "updater": {
      "pubkey": "RWSh+fg2Wyrd+eZ81SmwSqKJqNUqRnnXisTIBMTpOwzuRSRsWxVAkn1k",
      "endpoints": [
        "https://github.com/VoidChecksum/vibe-island/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "windows": { "installMode": "passive" }
    }
  }
}
